NEXT_PUBLIC_APP_NAME=전시 제어

# 센서·캡처: 미설정 또는 host = 노트북 /monitor (웹캠·마이크·비전), tablet = 태블릿 도면
# NEXT_PUBLIC_EXHIBIT_CAPTURE_SOURCE=tablet
# 호스트 전용: 웹캠 deviceId (미설정 시 시스템 기본 카메라). 마이크는 보통 웹캠 내장만 쓰고 OS 기본 입력으로 맞춤 → 아래 생략 가능
# NEXT_PUBLIC_EXHIBIT_HOST_VIDEO_DEVICE_ID=
# NEXT_PUBLIC_EXHIBIT_HOST_AUDIO_DEVICE_ID=

# Vision — /monitor(host)·태블릿 도면에서 프레임 → FastAPI /analyze (브라우저는 캡처만)
NEXT_PUBLIC_ENABLE_VISION_RUNTIME=false
# NEXT_PUBLIC_VISION_API_URL=/api/exhibit/analyze

# 태블릿 도면 SVG (벡터 — 확대해도 선명). 기본 /drawings/plan.svg
# NEXT_PUBLIC_TABLET_PLAN_SVG=/drawings/plan.svg

# 이벤트 헬스 스크립트: npm run check:event-bus
# EVENT_BRIDGE_BASE_URL=http://127.0.0.1:3001

# 벽면 TV /signage 가 서버에서 에이전트 상태를 가져올 때 (기본 http://127.0.0.1:8000)
# EXHIBITION_AGENT_BASE_URL=http://127.0.0.1:8000
