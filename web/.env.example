NEXT_PUBLIC_APP_NAME=전시 제어

# 센서·캡처: 미설정 또는 host = 노트북 /monitor (웹캠·마이크·비전), tablet = 태블릿 도면
# NEXT_PUBLIC_EXHIBIT_CAPTURE_SOURCE=tablet
# 호스트 전용: 웹캠 deviceId (미설정 시 시스템 기본 카메라). 마이크는 보통 웹캠 내장만 쓰고 OS 기본 입력으로 맞춤 → 아래 생략 가능
# NEXT_PUBLIC_EXHIBIT_HOST_VIDEO_DEVICE_ID=
# NEXT_PUBLIC_EXHIBIT_HOST_AUDIO_DEVICE_ID=

# Vision — /monitor(host)·태블릿 도면에서 프레임 → FastAPI /analyze (브라우저는 캡처만)
# 전시: true + 루트 .env USE_VISION_API=true · GOOGLE_APPLICATION_CREDENTIALS
NEXT_PUBLIC_ENABLE_VISION_RUNTIME=false
# 핫스팟 오프라인: npm run copy:mediapipe (postinstall) 로 WASM·모델 public/ 복사
# NEXT_PUBLIC_VISION_API_URL=/api/exhibit/analyze
# 로컬 얼굴 박스 감도 (높을수록 보수적 — 타인 패널·화면 오탐 줄임)
# NEXT_PUBLIC_FACE_MIN_DETECTION_CONF=0.62
# NEXT_PUBLIC_FACE_MIN_AREA_RATIO=0.012
# NEXT_PUBLIC_FACE_MAX_AREA_RATIO=0.22
# NEXT_PUBLIC_FACE_ASPECT_MIN=0.62
# NEXT_PUBLIC_FACE_ASPECT_MAX=1.38
# cover 화면 가운데 밴드 — 인원 집계(옆사람 오탐). 0.62 = 가로 62%만 인정
# NEXT_PUBLIC_FACE_CENTER_FOCUS_WIDTH=0.62
# NEXT_PUBLIC_FACE_CENTER_FOCUS_HEIGHT=0.72

# 태블릿 도면 — PDF 2장(자동) 또는 SVG 1장
# 배치·평면 PDF를 web/public/drawings/ 에 넣으면 dual-pdf 모드 (README-tablet-plan.txt)
# NEXT_PUBLIC_TABLET_PLAN_MODE=dual-pdf
# NEXT_PUBLIC_TABLET_PLAN_SITE_PDF=/drawings/tablet-site.pdf
# NEXT_PUBLIC_TABLET_PLAN_FLOOR_PDF=/drawings/tablet-floor.pdf
# NEXT_PUBLIC_TABLET_PLAN_SVG=/drawings/tablet-plan.svg

# 이벤트 헬스 스크립트: npm run check:event-bus
# EVENT_BRIDGE_BASE_URL=http://127.0.0.1:3001

# 벽면 TV /signage 가 서버에서 에이전트 상태를 가져올 때 (기본 http://127.0.0.1:8000)
# EXHIBITION_AGENT_BASE_URL=http://127.0.0.1:8000

# 장시간 무인 운영 안전망: N분마다 화면을 소프트 리셋(페이지 이동 없이 React 재마운트
# → 오디오/비전/인터벌 누수 정리). idle(관람객 없음)일 때만 동작. 기본 60분, 0 = 비활성.
# NEXT_PUBLIC_AUTO_REMOUNT_MIN=60
